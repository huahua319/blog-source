// ==========================================
// 自定义样式文件 (已净化)
// ==========================================

// --- 1. 主色调修改 (克莱因蓝) ---
$custom-blue = #3b74a8;
$custom-blue-light = #f0f5fa;
$custom-blue-hover = #2b567d;

a {
  color: $custom-blue !important;
  &:hover { color: $custom-blue-hover !important; }
}

.btn {
  background: transparent !important;
  color: $custom-blue !important;
  border-color: $custom-blue !important;
  &:hover {
    background: $custom-blue !important;
    color: white !important;
    border-color: $custom-blue !important;
  }
}

.menu-item-active a,
.sidebar-nav li.sidebar-nav-active {
  color: $custom-blue !important;
  border-bottom-color: $custom-blue !important;
}

.post-title-link::before {
  background-color: $custom-blue !important;
}

// --- 2. 卡片微圆角化 ---
.post-block, .sidebar-inner, .header-inner, .comments, .main-inner {
  border-radius: 8px !important;
}

.use-motion .post-block, .use-motion .sidebar-inner, .use-motion .header-inner {
  border-radius: 8px !important;
}

img { border-radius: 8px !important; }

.post-tags a {
  border-radius: 4px !important;
  padding: 1px 5px !important;
  background: $custom-blue-light !important;
  border-bottom: none !important;
  font-size: 0.85em !important;
  &:hover { background: $custom-blue !important; color: white !important; }
}

// 圆形头像
.site-author-image {
  border-radius: 50% !important;
}

// --- 3. 主页文章卡片流：每篇文章独立卡片 ---
// 首页 .main-inner 同时带 .posts-expand 类，让它透明化，下层卡片浮起来
.main-inner.posts-expand {
  background: transparent !important;
  box-shadow: none !important;
}

.posts-expand > .post-block {
  background: #fff !important;
  border-radius: 8px !important;
  padding: 30px 40px !important;
  margin-bottom: 24px !important;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06) !important;
}

// 暗黑模式适配（NexT 用 prefers-color-scheme 跟随系统）
@media (prefers-color-scheme: dark) {
  .posts-expand > .post-block {
    background: #2a2a2a !important;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3) !important;
  }
}
